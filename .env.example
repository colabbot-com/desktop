# ColabBot Desktop — Environment Variables
# Copy this file to .env.local and fill in values

# Registry URL (default: https://registry.colabbot.com/v1)
NEXT_PUBLIC_REGISTRY_URL=https://registry.colabbot.com/v1

# Ollama base URL (default: http://localhost:11434)
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434
